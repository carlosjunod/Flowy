# =============================================================================
# Flowy — Vercel (web app) env template
# =============================================================================
# Scope: env vars the Next.js app on Vercel needs to talk to Railway
#        (PocketBase + Redis) and third-party APIs.
#
# Worker-only vars (R2 upload creds, Reddit, yt-dlp, ffmpeg) are intentionally
# NOT listed here — they belong on the Railway worker service, not on Vercel.
#
# Workflow:
#   1. Copy this file to `.env` and fill in real values.
#   2. Either `vercel env pull` / `vercel env add` from CLI, or paste into
#      Vercel dashboard → Project → Settings → Environment Variables.
#   3. Redeploy. NEXT_PUBLIC_* vars are BAKED AT BUILD TIME — changing them
#      in the dashboard without redeploying does nothing.
# =============================================================================


# -----------------------------------------------------------------------------
# CRITICAL — the app will not run without these
# -----------------------------------------------------------------------------

# Railway PocketBase URL (exposed to the browser).
# Shape: https://<your-pb-service>.up.railway.app
# Read at: apps/web/lib/pocketbase.ts:34
NEXT_PUBLIC_PB_URL=https://your-pb.up.railway.app

# Server-side PocketBase URL used by API routes. Usually the same as
# NEXT_PUBLIC_PB_URL unless you have a private Vercel↔Railway path.
# Read at: apps/web/lib/pocketbase.ts:35, app/api/ingest/route.ts:78,
#          app/api/chat/route.ts:15, app/api/auth/{google,apple}/route.ts,
#          app/api/profile/interests/route.ts:50
PB_URL=https://your-pb.up.railway.app

# PocketBase superuser credentials. Used by /api/auth/google and /api/auth/apple
# to admin-authenticate before upserting a user record. MUST match the
# superuser you configured on the Railway PB instance — mismatch = every
# Google/Apple login returns 500.
# Read at: app/api/auth/google/route.ts:28-29, app/api/auth/apple/route.ts:26-27
PB_ADMIN_EMAIL=admin@tryflowy.app
PB_ADMIN_PASSWORD=

# Redis (BullMQ) connection. /api/ingest enqueues jobs here; the worker on
# Railway pulls them.
# GOTCHA: Vercel cannot reach Railway's internal DNS (*.railway.internal).
# You MUST enable "Public Networking" on the Redis service in Railway and use
# the public TCP proxy host here. Example shape:
#   redis://default:<password>@<proxy-host>.proxy.rlwy.net:<port>
# Read at: apps/web/lib/queue.ts:18
REDIS_URL=redis://default:password@your-proxy.proxy.rlwy.net:6379

# Anthropic API key for /api/chat.
# Read at: apps/web/lib/claude.ts:3
ANTHROPIC_API_KEY=sk-ant-...


# -----------------------------------------------------------------------------
# AUTH — Sign in with Google
# -----------------------------------------------------------------------------
# Required only if you enable Google login. All three must be set together.

# Google OAuth client ID (Web application) from
# https://console.cloud.google.com/apis/credentials
# Used as the `aud` claim when verifying Google id_tokens server-side.
# Read at: apps/web/lib/google-auth.ts:43
GOOGLE_CLIENT_ID=

# HMAC secret used to derive deterministic PocketBase passwords from each
# Google user's `sub`. MUST be ≥32 chars. Rotating it invalidates stored
# PB passwords — next login will transparently re-derive.
# Read at: app/api/auth/google/route.ts:20
GOOGLE_PASSWORD_SECRET=

# Same value as GOOGLE_CLIENT_ID, exposed to the browser so Google Identity
# Services can render the Sign-in button. If unset, the Google button is
# hidden on /login.
# Read at: apps/web/app/(auth)/login/page.tsx:52
NEXT_PUBLIC_GOOGLE_CLIENT_ID=


# -----------------------------------------------------------------------------
# AUTH — Sign in with Apple (SIWA)
# -----------------------------------------------------------------------------
# Required only if you enable Apple login or ship the iOS/macOS app.

# HMAC secret used to derive deterministic PB passwords from each Apple user's
# `sub`. MUST be ≥32 chars. Same rotation semantics as GOOGLE_PASSWORD_SECRET.
# Read at: app/api/auth/apple/route.ts:18
SIWA_PASSWORD_SECRET=

# Apple bundle ID — the `aud` claim on id_tokens issued by the NATIVE iOS app.
# Defaults to "app.tryflowy.app". Only change if your bundle ID differs.
# Read at: apps/web/lib/apple-auth.ts:39,
#          apps/web/app/.well-known/apple-app-site-association/route.ts:8
APPLE_CLIENT_ID=app.tryflowy.app

# Apple Services ID — the `aud` claim on id_tokens issued by the WEB SIWA flow.
# Create at developer.apple.com → Identifiers → Services IDs. Distinct from
# the bundle ID above. Leave blank to disable the web Apple button entirely.
# Read at: apps/web/lib/apple-auth.ts:40
APPLE_WEB_CLIENT_ID=

# Same value as APPLE_WEB_CLIENT_ID, exposed to the browser.
# Read at: apps/web/app/(auth)/login/page.tsx:53
NEXT_PUBLIC_APPLE_WEB_CLIENT_ID=

# Where Apple redirects after the popup flow. MUST exactly match one of the
# Return URLs configured on the Apple Services ID. For production this should
# be your Vercel prod URL + "/login", e.g. https://tryflowy.app/login
# Read at: apps/web/app/(auth)/login/page.tsx:54
NEXT_PUBLIC_APPLE_REDIRECT_URI=https://tryflowy.app/login

# Apple Team ID — 10-char alphanumeric from developer.apple.com → Membership.
# Used to build the appID entry in /.well-known/apple-app-site-association
# for Universal Links. If unset, AASA falls back to "TEAMIDMISSING" and
# Universal Links silently fail to register on devices.
# Read at: apps/web/app/.well-known/apple-app-site-association/route.ts:7
APPLE_TEAM_ID=


# -----------------------------------------------------------------------------
# RECOMMENDED — degraded UX if unset, but app still runs
# -----------------------------------------------------------------------------

# Public base URL for R2-hosted assets. Without it, image thumbnails in the
# inbox render as empty <img> tags.
# Read at: components/inbox/ItemCard.tsx:59, components/inbox/ItemDrawer.tsx:45,51
NEXT_PUBLIC_R2_PUBLIC_URL=https://files.tryflowy.app

# OpenAI API key for text embeddings. If unset, embeddings silently fall back
# to a deterministic hash (chat search quality drops noticeably).
# Read at: apps/web/lib/claude.ts:4
OPENAI_API_KEY=

# Internal signing secret. 32+ chars. Used for session/JWT signing where
# applicable. Harmless to set now to future-proof.
JWT_SECRET=


# -----------------------------------------------------------------------------
# DO NOT SET ON VERCEL — these belong on the Railway worker service
# -----------------------------------------------------------------------------
# Listed here only so you don't accidentally paste them into Vercel:
#
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET,
#   R2_PUBLIC_URL            -> worker uploads files to R2
#   REDDIT_CLIENT_ID, REDDIT_CLIENT_SECRET, REDDIT_USER_AGENT
#                            -> worker fetches Reddit posts
#   YTDLP_PATH, FFMPEG_PATH  -> worker binaries for video processing
#   TEST_USER_EMAIL, TEST_USER_PASSWORD
#                            -> local/e2e tests only
# =============================================================================
