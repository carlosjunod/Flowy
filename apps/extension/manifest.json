{
  "manifest_version": 3,
  "name": "Flowy — Save to Inbox",
  "short_name": "Flowy",
  "version": "0.1.0",
  "description": "Bookmark pages, links, and images to your Flowy inbox.",
  "author": "Flowy",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://tryflowy.app/*"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Save to Flowy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current tab to Flowy"
    }
  }
}
