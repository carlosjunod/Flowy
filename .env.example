# PocketBase — local DB + auth
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=admin@tryflowy.app
PB_ADMIN_PASSWORD=changeme_local

# Anthropic Claude API (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Redis (BullMQ queue)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tryflowy-files
R2_PUBLIC_URL=https://files.tryflowy.app

# OpenAI — Whisper transcription for video items (CYCLE-10)
OPENAI_API_KEY=

# Optional paths for yt-dlp + ffmpeg when not already on the worker's PATH
# (Apple Silicon Homebrew puts ffmpeg at /opt/homebrew/bin/ffmpeg)
# YTDLP_PATH=
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Auth / session — 32-char minimum secret for internal signing
JWT_SECRET=changeme_local_32chars_minimum_xxxxxx

# Sign in with Apple — HMAC secret used to derive PocketBase passwords per Apple user
# Must be ≥32 chars. Rotation is safe: next SIWA login transparently re-derives.
SIWA_PASSWORD_SECRET=changeme_siwa_secret_32chars_minimum_xxxx

# Apple Client ID (aud claim in Apple identity tokens) — defaults to app.tryflowy.app
APPLE_CLIENT_ID=app.tryflowy.app

# Apple Team ID — 10-char alphanumeric from developer.apple.com → Membership.
# Used to build the appID in /.well-known/apple-app-site-association for Universal Links.
APPLE_TEAM_ID=TEAMIDMISSING

# Sign in with Google — OAuth client ID from https://console.cloud.google.com/apis/credentials.
# Used as the `aud` claim when verifying Google identity tokens. The client-side
# Google Identity Services button is configured with this same value (exposed
# publicly via NEXT_PUBLIC_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=

# Google HMAC secret — mirrors SIWA_PASSWORD_SECRET. Used to derive PocketBase
# passwords deterministically from a Google `sub`. Must be ≥32 chars.
GOOGLE_PASSWORD_SECRET=changeme_google_secret_32chars_minimum_xxx

# Next.js — public URLs exposed to the browser
NEXT_PUBLIC_PB_URL=http://localhost:8090
NEXT_PUBLIC_APP_URL=http://localhost:4000
# Same value as GOOGLE_CLIENT_ID — exposed to the browser so Google Identity
# Services can render the Sign-in-with-Google button with the right client ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Test user for E2E/smoke tests
TEST_USER_EMAIL=test@tryflowy.app
TEST_USER_PASSWORD=test_password_12345
