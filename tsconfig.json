{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["./apps/web/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "worker/src/types/modules.d.ts"
  ],
  "exclude": ["node_modules", "apps/web", "apps/web/**/*"]
}
